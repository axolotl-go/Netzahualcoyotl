<section
  class="relative min-h-[70vh] md:min-h-[85vh] flex items-center overflow-hidden"
  id="inicio"
>
  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="/Fondo.jpeg"
      alt="Campus escolar"
      class="w-full h-full object-cover"
      loading="eager"
    />

    <!-- Gradiente ajustado -->
    <div
      class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-academic-charcoal/95 via-academic-charcoal/85 to-transparent"
    >
    </div>
  </div>

  <!-- Content -->
  <div
    class="max-w-[1280px] mx-auto px-4 md:px-10 lg:px-20 relative z-10 w-full"
  >
    <div class="max-w-3xl space-y-6 md:space-y-8">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 bg-primary/20 backdrop-blur-sm border border-primary/30 px-3 py-1.5 rounded-full"
      >
        <span class="h-2 w-2 rounded-full bg-primary animate-pulse"></span>
        <span
          class="text-white text-[10px] md:text-xs font-bold uppercase tracking-wider"
        >
          Excelencia Educativa en Torreón
        </span>
      </div>

      <!-- Title -->
      <h1
        class="text-white text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight"
      >
        Forjando Liderazgo y
        <span class="text-primary italic block sm:inline"> Conocimiento </span>
      </h1>

      <!-- Description -->
      <p
        class="text-slate-300 text-base sm:text-lg md:text-xl leading-relaxed max-w-xl"
      >
        Formación integral con visión crítica, valores sólidos y excelencia
        académica.
      </p>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 pt-2">
        <a href="#oferta">
          <button
            class="w-full sm:w-auto bg-primary hover:bg-primary-dark text-white px-6 py-3 md:px-8 md:py-4 rounded-lg text-sm md:text-base font-bold shadow-lg transition-all active:scale-95"
          >
            VER OFERTA
          </button>
        </a>

        <a href="#contacto">
          <button
            class="w-full sm:w-auto bg-white/10 backdrop-blur-md text-white border border-white/20 px-6 py-3 md:px-8 md:py-4 rounded-lg text-sm md:text-base font-bold hover:bg-white hover:text-academic-charcoal transition-all active:scale-95"
          >
            CONOCER PLANTEL
          </button>
        </a>
      </div>
    </div>
  </div>
</section>
