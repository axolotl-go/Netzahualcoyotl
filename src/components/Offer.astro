---
import { LucideVerified, Clock, Terminal } from "@lucide/astro";
---

<section class="py-24 px-6 lg:px-20 bg-slate-50" id="oferta">
  <div class="max-w-[1280px] mx-auto">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      <div class="relative">
        <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl">
          <img
            alt="Students in Classroom"
            class="w-full h-full object-cover"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDPzZw8aP_nj_v1QFOzrZ3xBlhRRdwHwQu3V6EzmNNtJy1yGLSsDmCfmcLbhf5LtSZVariqZvg8VIVNwH3RF9mYdpdT_vDBF_YBIj0AlMwuLotIlqd_CyovVfaeFp9OeCY-Fl65bCobY8TouwE8hPE81rsUC_k3f__tPkxZhJPNHYRrU_sqVKgQmtGsQBdWzf_P58BW9IHbcOZgCKDGByIPWpqeWBuw9qf6gYbmTKMcO4wcBYqCI74IIwnfB2zwTgjSuC-rrW3Fjlpq"
          />
        </div>
        <div
          class="absolute -bottom-10 -right-10 bg-white p-8 rounded-3xl shadow-2xl hidden md:block max-w-xs"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="p-2 bg-primary/10 rounded-lg text-primary">
              <LucideVerified />
            </div>
            <span class="font-black text-sm uppercase">Excelencia SEP</span>
          </div>
          <p class="text-sm text-slate-500 font-medium">
            Programa oficial enriquecido con talleres de tecnología y artes.
          </p>
        </div>
      </div>
      <div class="space-y-10">
        <div>
          <h2
            class="text-primary text-sm font-black uppercase tracking-[0.3em] mb-4"
          >
            Oferta Educativa
          </h2>
          <h3 class="text-4xl lg:text-5xl font-900 text-academic-charcoal mb-6">
            Preparación para el Nivel Medio Superior
          </h3>
          <p class="text-slate-600 text-lg">
            Nuestro currículo está diseñado para brindar las herramientas
            analíticas necesarias en un mundo globalizado.
          </p>
        </div>
        <div class="space-y-6">
          <div
            class="flex items-start gap-6 p-6 bg-white rounded-2xl shadow-sm border border-slate-100 hover:border-primary/20 transition-all"
          >
            <div class="bg-primary text-white p-3 rounded-xl">
              <Clock />
            </div>
            <div>
              <h4 class="text-xl font-800 text-academic-charcoal">
                Flexibilidad de Turnos
              </h4>
              <p class="text-slate-500 mt-1">
                Matutino: 7:00 AM - 1:30 PM <br />
                Vespertino: 1:45 PM - 8:15 PM
              </p>
            </div>
          </div>
          <div
            class="flex items-start gap-6 p-6 bg-white rounded-2xl shadow-sm border border-slate-100 hover:border-primary/20 transition-all"
          >
            <div class="bg-academic-charcoal text-white p-3 rounded-xl">
              <Terminal />
            </div>
            <div>
              <h4 class="text-xl font-800 text-academic-charcoal">
                Talleres y Co-curriculares
              </h4>
              <p class="text-slate-500 mt-1">
                Robótica, Club de Ciencias, Música, Teatro y ligas deportivas
                internas.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
