---
import navigation from "../data/navigation.json";

var Open = true;
---

<header
  class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-lg border-b border-slate-200"
>
  <div
    class="max-w-7xl mx-auto flex items-center justify-between px-6 lg:px-20 h-20"
  >
    <!-- Branding -->
    <div class="flex items-center gap-3">
      <div class="flex flex-col leading-tight">
        <h1
          class="text-lg lg:text-xl font-extrabold tracking-tight text-slate-900"
        >
          SECUNDARIA GENERAL NO. 10
        </h1>
        <span
          class="text-[10px] font-bold tracking-[0.2em] text-primary uppercase"
        >
          Netzahualcóyotl
        </span>
      </div>
    </div>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8">
      {
        navigation.data.map((item) => (
          <a
            href={item.link}
            class="relative text-sm font-semibold tracking-wide text-slate-600 hover:text-primary transition-colors duration-200 after:absolute after:left-0 after:-bottom-1 after:h-[2px] after:w-0 after:bg-primary after:transition-all hover:after:w-full"
          >
            {item.title}
          </a>
        ))
      }
    </nav>

    <!-- CTA -->
    <div class="hidden sm:flex items-center gap-4">
      <button
        class="bg-slate-900 hover:bg-primary text-white text-xs lg:text-sm font-bold px-5 py-2.5 rounded-md transition-all shadow-md hover:-translate-y-[1px] active:translate-y-0"
      >
        INSCRIPCIONES
      </button>
    </div>

    <!-- Mobile Toggle -->
    <button
      class="lg:hidden flex items-center justify-center w-10 h-10 rounded-md border border-slate-300"
    >
      -
    </button>
  </div>
</header>
