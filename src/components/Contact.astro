---
import { Mail, Phone, Map } from "@lucide/astro";

const contactItems = [
  {
    icon: Phone,
    label: "Teléfono",
    value: "+52 871 732 7269",
  },
  {
    icon: Mail,
    label: "Email",
    value: "secundariadieztrc@gmail.com",
  },
  {
    icon: Map,
    label: "Ubicación",
    value: "Calz Moctezuma, Tierra y Libertad, 27040 Torreón, Coah.",
  },
];
---

<section class="py-20 lg:px-20 bg-slate-50" id="contacto">
  <div
    class="bg-white rounded-3xl overflow-hidden shadow-xl border border-slate-100 flex flex-col lg:flex-row"
  >
    <!-- INFO -->
    <div class="p-5 md:p-10 lg:w-2/5 bg-academic-charcoal text-white">
      <h3 class="text-2xl font-extrabold mb-10">Centro de Atención</h3>

      <div class="space-y-4">
        {
          contactItems.map(({ icon: Icon, label, value }) => (
            <div class="flex items-start gap-5">
              <div class="p-2 bg-primary rounded-lg">
                <Icon />
              </div>
              <div>
                <p class="text-primary text-xs font-bold uppercase tracking-widest wrap-normal">
                  {label}
                </p>
                <p class=" font-semibold text-[14px] md:text-lg">{value}</p>
              </div>
            </div>
          ))
        }

        <!-- Horario -->
        <div class="pt-8">
          <p
            class="text-slate-400 text-xs uppercase font-bold tracking-widest mb-3"
          >
            Horario
          </p>
          <div
            class="flex justify-between border-b border-white/10 py-2 text-sm"
          >
            <span>Lunes - Viernes</span>
            <span class="font-semibold">7:00 - 20:30</span>
          </div>
        </div>
      </div>
    </div>

    <!-- MAP -->
    <div class="lg:w-3/5 relative">
      <div class="w-full h-[400px] lg:h-full">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1153.937694897097!2d-103.41403096964987!3d25.550938069228547!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x868fdbaf1462d4e5%3A0x62e8723c4a16630c!2sSecundaria%20General%20No.%2010%2C%20%22Netzahualc%C3%B3yotl%22!5e0!3m2!1ses-419!2smx!4v1776049092101!5m2!1ses-419!2smx"
          class="w-full h-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Secundaria 10 Torreón"></iframe>
      </div>

      <!-- Overlay opcional -->
      <div
        class="absolute top-6 left-6 bg-white/90 backdrop-blur rounded-xl px-5 py-3 shadow-md"
      >
        <p class="text-sm font-semibold text-academic-charcoal">
          Visítanos en Torreón
        </p>
      </div>
    </div>
  </div>
</section>
