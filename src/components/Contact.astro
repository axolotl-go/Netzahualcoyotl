---
import { Mail, Phone, Map } from "@lucide/astro";

const contactItems = [
  {
    icon: Phone,
    label: "Teléfono",
    value: "+52 871 642 0752",
  },
  {
    icon: Mail,
    label: "Email",
    value: "secundaria10trc@gmail.com",
  },
  {
    icon: Map,
    label: "Ubicación",
    value:
      "Av. Universidad S/N, Col. Sol de Oriente, Torreón, Coahuila. CP 27000",
  },
];
---

<section class="py-20 lg:px-20 bg-slate-50">
  <div class="bg-white rounded-3xl overflow-hidden shadow-xl border border-slate-100 flex flex-col lg:flex-row">

    <!-- INFO -->
    <div class="p-5 md:p-10 lg:w-2/5 bg-academic-charcoal text-white">
      <h3 class="text-2xl font-extrabold mb-10">Centro de Atención</h3>

      <div class="space-y-4">
        {contactItems.map(({ icon: Icon, label, value }) => (
          <div class="flex items-start gap-5">
            <div class="p-2 bg-primary rounded-lg">
              <Icon />
            </div>
            <div>
              <p class="text-primary text-xs font-bold uppercase tracking-widest wrap-normal">
                {label}
              </p>
              <p class=" font-semibold text-[14px] md:text-lg">
                {value}
              </p>
            </div>
          </div>
        ))}

        <!-- Horario -->
        <div class="pt-8">
          <p class="text-slate-400 text-xs uppercase font-bold tracking-widest mb-3">
            Horario
          </p>
          <div class="flex justify-between border-b border-white/10 py-2 text-sm">
            <span>Lunes - Viernes</span>
            <span class="font-semibold">7:00 - 20:30</span>
          </div>
        </div>
      </div>
    </div>

    <!-- MAP -->
    <div class="lg:w-3/5 relative">
      <div class="w-full h-[400px] lg:h-full">
        <iframe
          src="https://www.google.com/maps?q=25.5513845,-103.4150348&z=15&output=embed"
          class="w-full h-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Secundaria 10 Torreón"
        ></iframe>
      </div>

      <!-- Overlay opcional -->
      <div class="absolute top-6 left-6 bg-white/90 backdrop-blur rounded-xl px-5 py-3 shadow-md">
        <p class="text-sm font-semibold text-academic-charcoal">
          Visítanos en Torreón
        </p>
      </div>
    </div>

  </div>
</section>